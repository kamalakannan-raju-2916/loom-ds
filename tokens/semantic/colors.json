{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Loom Semantic Color Tokens",
    "description": "UI role tokens with Light and Dark mode values. References DSG primitives.",
    "version": "1.0.0",
    "modes": ["Light", "Dark"]
  },

  "semantic": {
    "surface": {
      "page":      { "Light": "#FFFFFF", "Dark": "#141516" },
      "primary":   { "Light": "#FFFFFF", "Dark": "#202123" },
      "secondary": { "Light": "#F5F5F5", "Dark": "#141516" },
      "tertiary":  { "Light": "#E9E9E9", "Dark": "#07080A" },
      "elevated":  { "Light": "#FFFFFF", "Dark": "#39393B" },
      "overlay":   { "Light": "rgba(0,0,0,0.5)", "Dark": "rgba(0,0,0,0.7)" }
    },

    "text": {
      "primary":      { "Light": "#181818", "Dark": "#E7E7E7" },
      "secondary":    { "Light": "#626262", "Dark": "#9C9C9D" },
      "tertiary":     { "Light": "#939393", "Dark": "#6A6B6C" },
      "disabled":     { "Light": "#C4C4C4", "Dark": "#39393B" },
      "on-accent":    { "Light": "#FFFFFF", "Dark": "#FFFFFF" },
      "link":         { "Light": "#006AFF", "Dark": "#00A6FF" },
      "link-visited": { "Light": "#663399", "Dark": "#A385C2" }
    },

    "border": {
      "default": { "Light": "#DCDCDC", "Dark": "#39393B" },
      "strong":  { "Light": "#C4C4C4", "Dark": "#525354" },
      "subtle":  { "Light": "#E9E9E9", "Dark": "#202123" },
      "focus":   { "Light": "#2C66DD", "Dark": "#5685E4" }
    },

    "status": {
      "success-bg":   { "Light": "#E7F3ED", "Dark": "#064422" },
      "success-text": { "Light": "#096633", "Dark": "#86C4A2" },
      "warning-bg":   { "Light": "#FDF8E9", "Dark": "#674E0A" },
      "warning-text": { "Light": "#906D0D", "Dark": "#F3D37C" },
      "danger-bg":    { "Light": "#FAECEA", "Dark": "#5D1A12" },
      "danger-text":  { "Light": "#BA3425", "Dark": "#E0887F" },
      "info-bg":      { "Light": "#EAF0FC", "Dark": "#112E68" },
      "info-text":    { "Light": "#225CCF", "Dark": "#96B3EE" }
    }
  }
}
